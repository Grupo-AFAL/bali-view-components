<div class="h-[500px] bg-base-200 p-4 ml-64">
  <%= render Bali::SideMenu::Component.new(current_path: '/dashboard', fixed: true, collapsable: collapsable) do |c|
    c.with_list(title: 'Principal') do |list|
      list.with_item(name: 'Dashboard', href: '/dashboard', icon: 'layout-dashboard')
      list.with_item(name: 'Projects', href: '/projects', icon: 'folder-open')
      list.with_item(name: 'Team', href: '/team', icon: 'users')
    end

    c.with_list(title: 'Settings') do |list|
      list.with_item(name: 'Account', href: '/account', icon: 'user')
      list.with_item(name: 'Preferences', href: '/preferences', icon: 'settings')
    end

    c.with_bottom_item(name: 'Ana García', href: '/profile', icon: 'user')
    c.with_bottom_item(name: 'Sign Out', href: '/sign_out', icon: 'log-out')
  end %>
</div>
