<%= tag.div(**container_attributes) do %>
  <%# App Bar %>
  <div class="document-editor-app-bar flex items-center gap-3 px-4 h-14 border-b border-base-300 shrink-0">
    <%# Left: TOC toggle %>
    <%= render Bali::Button::Component.new(variant: :ghost, size: :sm, class: "btn-square",
          data: { action: "document-editor#toggleToc" }, title: "Toggle table of contents") do %>
      <%= render Bali::Icon::Component.new('panel-left', size: :small) %>
    <% end %>

    <%# Center: Title %>
    <div class="flex-1 min-w-0">
      <% if editable? %>
        <%= tag.input type: "text", value: title,
              class: "input input-ghost text-lg font-semibold w-full max-w-md",
              data: { document_editor_target: "titleInput", action: "change->document-editor#titleChanged" },
              placeholder: "Untitled document" %>
      <% else %>
        <h1 class="text-lg font-semibold truncate"><%= title %></h1>
      <% end %>
    </div>

    <%# Right: Save status + Panel toggles + Close %>
    <div class="flex items-center gap-1">
      <span class="text-xs text-base-content/50 shrink-0" data-document-editor-target="saveStatus"></span>
      <% if editable? %>
        <button type="button"
                class="btn btn-ghost btn-sm gap-1"
                data-action="document-editor#save"
                data-document-editor-target="saveButton"
                disabled
                title="Save changes">
          <%= render Bali::Icon::Component.new('save', size: :small) %>
          Save
        </button>
      <% end %>
      <% if comments? %>
        <%= render Bali::Button::Component.new(variant: :ghost, size: :sm, class: "btn-square",
              data: { action: "document-editor#toggleComments", document_editor_target: "commentsToggle" },
              title: "Toggle comments") do %>
          <%= render Bali::Icon::Component.new('message-square', size: :small) %>
        <% end %>
      <% end %>

      <% if versions? %>
        <%= render Bali::Button::Component.new(variant: :ghost, size: :sm, class: "btn-square",
              data: { action: "document-editor#toggleHistory", document_editor_target: "historyToggle" },
              title: "Toggle version history") do %>
          <%= render Bali::Icon::Component.new('history', size: :small) %>
        <% end %>
      <% end %>

      <% if export %>
        <%= render Bali::Dropdown::Component.new(align: :right) do |dropdown| %>
          <% dropdown.with_trigger(class: "btn-ghost btn-sm btn-square") do %>
            <%= render Bali::Icon::Component.new('download', size: :small) %>
          <% end %>
          <% dropdown.with_item(tag: :button, data: { action: "document-editor#exportPdf" }) { "Export PDF" } %>
          <% dropdown.with_item(tag: :button, data: { action: "document-editor#exportDocx" }) { "Export DOCX" } %>
        <% end %>
      <% end %>

      <div class="divider divider-horizontal mx-1 h-6"></div>

      <%= link_to close_url, class: "btn btn-ghost btn-sm btn-square",
            data: { action: "document-editor#close" }, title: "Close editor" do %>
        <%= render Bali::Icon::Component.new('x', size: :small) %>
      <% end %>
    </div>
  </div>

  <%# Main Content Area: TOC | Editor | Right Panel %>
  <div class="flex-1 flex overflow-hidden">
    <%# Left: TOC Panel (populated via React portal from BlockNote) %>
    <div class="document-editor-toc w-56 border-r border-base-300 overflow-y-auto shrink-0 p-4 hidden"
         data-document-editor-target="tocPanel">
      <h3 class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-3">Contents</h3>
      <div id="<%= toc_container_id %>"></div>
    </div>

    <%# Center: Editor %>
    <div class="flex-1 overflow-y-auto" data-action="input->document-editor#contentChanged" data-document-editor-target="editorArea">
      <%# Preview Banner (hidden by default, shown when previewing a version) %>
      <div class="hidden bg-info/10 border-b border-info/20 px-6 py-2.5 flex items-center justify-between"
           data-document-editor-target="previewBanner">
        <div class="flex items-center gap-2 text-sm">
          <%= render Bali::Icon::Component.new('eye', size: :small) %>
          <span>Previewing <strong data-document-editor-target="previewVersionLabel"></strong></span>
          <span class="text-base-content/50">— read only</span>
        </div>
        <%= render Bali::Button::Component.new(name: "Back to current", variant: :ghost, size: :sm,
              data: { action: "document-editor#exitPreview" }) do |btn| %>
          <% btn.with_icon("x", size: :small) %>
        <% end %>
      </div>
      <div class="px-12 py-8">
        <%= render Bali::BlockEditor::Component.new(
          initial_content: initial_content,
          editable: editable?,
          input_name: editable? ? input_name : nil,
          table_of_contents: true,
          table_of_contents_container_id: toc_container_id,
          comments: @comments_config || false,
          comments_container_id: comments? ? comments_container_id : nil,
          export: export,
          show_export_buttons: false,
          export_filename: export_filename,
          ai_url: ai_url,
          mentions_url: mentions_url,
          mentions: mentions
        ) %>
      </div>
    </div>

    <%# Right: Comments Panel %>
    <% if comments? %>
      <div class="document-editor-panel w-80 border-l border-base-300 overflow-y-auto shrink-0 hidden"
           data-document-editor-target="commentsPanel">
        <div class="p-4">
          <h3 class="text-sm font-semibold text-base-content/60 uppercase tracking-wider mb-3">Comments</h3>
          <div class="bn-mantine" data-document-editor-target="commentsList" id="<%= comments_container_id %>">
          </div>
        </div>
      </div>
    <% end %>

    <%# Right: History Panel %>
    <% if versions? %>
      <div class="document-editor-panel w-80 border-l border-base-300 overflow-y-auto shrink-0 hidden"
           data-document-editor-target="historyPanel">
        <div class="p-4">
          <h3 class="text-sm font-semibold text-base-content/60 uppercase tracking-wider mb-3">Version History</h3>
          <div data-document-editor-target="versionsList">
            <%= render Bali::Loader::Component.new(size: :md) %>
          </div>
        </div>
      </div>

      <template data-document-editor-target="versionTemplate">
        <div class="version-item group">
          <div class="flex items-center justify-between mb-1.5">
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-base-content">
              <%= render Bali::Icon::Component.new('clock', size: :small, class: "opacity-50") %>
              <span data-version-field="number"></span>
            </span>
            <span class="text-[11px] text-base-content/40 tabular-nums" data-version-field="time"></span>
          </div>
          <div class="flex items-center gap-1.5 mb-1">
            <span class="inline-flex items-center justify-center w-4 h-4 rounded-full bg-base-content/10 text-[9px] font-bold text-base-content/60 shrink-0" data-version-field="avatar"></span>
            <span class="text-xs text-base-content/60" data-version-field="author"></span>
          </div>
          <p class="text-[11px] text-base-content/40 leading-relaxed mb-1 italic hidden" data-version-field="summary"></p>
          <div class="flex items-center gap-1 mt-2 pt-2 border-t border-base-200/60">
            <button type="button" class="version-btn version-btn-preview" data-action="document-editor#previewVersion">
              <%= render Bali::Icon::Component.new('eye', size: :small) %> Preview
            </button>
            <button type="button" class="version-btn version-btn-restore" data-action="document-editor#restoreVersion">
              <%= render Bali::Icon::Component.new('rotate-ccw', size: :small) %> Restore
            </button>
          </div>
        </div>
      </template>
    <% end %>
  </div>
<% end %>
