<%= form_with url: @url, method: :get, builder: Bali::FormBuilder, data: { turbo_frame: "_top" } do |f| %>
  <div class="flex flex-nowrap overflow-x-auto sm:flex-wrap gap-2 items-center py-1 pb-2 sm:pb-1 scrollbar-hide">
    <% if search_enabled? %>
      <div class="w-32 sm:w-80 shrink-0">
        <div class="w-full <%= 'join' if search_icon %>">
          <%= icon_addon(search_icon) %>

          <%= tag.input(
                type: "text",
                name: @search[:field_name],
                value: @search[:value],
                placeholder: @search[:placeholder],
                class: "input input-bordered input-sm w-full #{'join-item rounded-l-none border-l-0' if search_icon}"
              ) %>
        </div>
      </div>
    <% end %>

    <% @filters.each do |filter| %>
      <div class="<%= toggle_group?(filter) ? '' : 'w-auto sm:max-w-56' %> shrink-0">
        <% if toggle_group?(filter) %>
          <%# Hidden input to ensure the parameter is sent even when nothing is checked %>
          <input type="hidden" name="<%= filter_field_name(filter) %>" value="" />

          <div class="join">
            <% filter[:collection].each do |label, value| %>
              <%
                current_values = Array.wrap(filter[:value] || filter[:default]).map(&:to_s)
                is_checked = current_values.include?(value.to_s)
              %>
              <input type="checkbox"
                     name="<%= filter_field_name(filter) %>"
                     value="<%= value %>"
                     class="btn btn-sm join-item btn-outline border-base-content/20 checked:!bg-primary/10 checked:!text-primary checked:!border-primary"
                     aria-label="<%= label %>"
                     <%= "checked" if is_checked %> />
            <% end %>
          </div>
        <% elsif date_filter?(filter) %>
          <div class="<%= 'join' if filter[:icon] %>">
            <%= icon_addon(filter[:icon]) %>

            <%= f.date_field(
                  filter_field_name(filter),
                  value: filter[:value] || filter[:default],
                  placeholder: filter[:placeholder] || filter[:label],
                  alt_input_class: "input input-bordered input-sm w-full #{'join-item rounded-l-none border-l-0 max-sm:w-24 max-sm:px-1' if filter[:icon]}",
                  wrapper_options: { class: "flatpickr #{'grow' if filter[:icon]}" },
                  **({ mode: "range" } if date_range?(filter))
                ) %>
          </div>
        <% elsif slim_select?(filter) %>
          <%= f.slim_select_field(
                filter_field_name(filter),
                filter[:collection],
                {
                  include_blank: filter[:blank],
                  size: :sm,
                  addon_left: (render Bali::Icon::Component.new(filter[:icon], class: 'w-4 h-4') if filter[:icon])
                },
                { class: "w-full #{'max-sm:w-16' if filter[:icon]}", select_class: ('max-sm:w-16' if filter[:icon]) }
              ) %>
        <% else %>
          <div class="<%= 'join' if filter[:icon] %>">
            <%= icon_addon(filter[:icon]) %>

            <%= f.select(
              filter_field_name(filter),
              options_for_select(
                filter[:collection],
                filter[:value] || filter[:default]
              ),
              { include_blank: filter[:blank] },
              class: "select select-bordered select-sm w-full bg-none max-sm:pr-2 #{'join-item rounded-l-none border-l-0 max-sm:w-16 max-sm:px-1' if filter[:icon]}"
            ) %>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="flex gap-2 items-center shrink-0">
      <%= render Bali::Button::Component.new(
        name: apply_button_text,
        type: :submit,
        variant: :primary,
        size: :sm,
        icon_name: 'search',
        responsive: true
      ) %>

      <% if show_clear? %>
        <%= render Bali::Link::Component.new(
          name: clear_button_text,
          href: @url,
          variant: :ghost,
          size: :sm,
          icon_name: 'x',
          responsive: true
        ) %>
      <% end %>
    </div>
  </div>
<% end %>
