<%= render Bali::Card::Component.new(style: :bordered) do %>
  <h3 class="card-title text-lg mb-4">Form Example</h3>
  <%= render Bali::Columns::Component.new(cols: 1, cols_md: 2, gap: :lg) do %>
    <div>
      <label class="label"><span class="label-text">First Name</span></label>
      <input type="text" class="input input-bordered w-full" placeholder="John" />
    </div>
    <div>
      <label class="label"><span class="label-text">Last Name</span></label>
      <input type="text" class="input input-bordered w-full" placeholder="Doe" />
    </div>
    <div>
      <label class="label"><span class="label-text">Email</span></label>
      <input type="email" class="input input-bordered w-full" placeholder="john@example.com" />
    </div>
    <div>
      <label class="label"><span class="label-text">Phone</span></label>
      <input type="tel" class="input input-bordered w-full" placeholder="+1 (555) 000-0000" />
    </div>
  <% end %>

  <div class="mt-4">
    <label class="label"><span class="label-text">Notes</span></label>
    <textarea class="textarea textarea-bordered w-full" rows="3" placeholder="Additional notes..."></textarea>
  </div>
<% end %>
