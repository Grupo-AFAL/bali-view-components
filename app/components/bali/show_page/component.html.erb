<div class="show-page-component">
  <%= render_breadcrumbs %>

  <%= render Bali::PageHeader::Component.new(back: back, class: breadcrumb_spacer_class) do |header| %>
    <% header.with_title do %>
      <div class="flex items-center gap-3">
        <%= title %>
        <% if title_tags? %>
          <% title_tags.each do |tag| %>
            <%= tag %>
          <% end %>
        <% end %>
      </div>
    <% end %>
    <% if subtitle.present? %>
      <% header.with_subtitle(subtitle) %>
    <% end %>

    <%= render_actions_bar %>
  <% end %>

  <% if body? %>
  <div class="mt-6">
    <% if sidebar? %>
      <%= render_sidebar_layout(body, sidebar) %>
    <% else %>
      <%= body %>
    <% end %>
  </div>
  <% end %>
</div>
