<div class="show-page-component">
  <%= render_breadcrumbs %>

  <%= render Bali::PageHeader::Component.new(back: back, class: breadcrumb_spacer_class) do |header| %>
    <% header.with_title do %>
      <div class="flex items-center gap-3">
        <%= title %>
        <% if title_tags? %>
          <% title_tags.each do |tag| %>
            <%= tag %>
          <% end %>
        <% end %>
      </div>
    <% end %>
    <% if subtitle.present? %>
      <% header.with_subtitle(subtitle) %>
    <% end %>

    <% if actions? %>
      <div class="flex items-center gap-2">
        <% actions.each do |action| %><%= action %><% end %>
      </div>
    <% end %>
  <% end %>

  <% if body? %>
  <div class="mt-6">
    <% if sidebar? %>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2"><%= body %></div>
        <div class="space-y-6"><%= sidebar %></div>
      </div>
    <% else %>
      <%= body %>
    <% end %>
  </div>
  <% end %>
</div>
