<%= tag.div(id: container_id, **table_container_options) do %>
  <%= tag.table(**options) do %>
    <thead>
      <tr>
        <% if bulk_actions? %>
          <th>
            <%= tag.input type: 'checkbox', class: 'checkbox', data: { action: 'table#toggleAll', table_target: 'toggleAll' } %>
          </th>
        <% end %>
        <% visible_headers.each do |header| %>
          <%= header %>
        <% end %>
      </tr>
    </thead>
    <%= tag.tbody(**tbody_options) do %>
      <% if rows.any? %>
        <% if grouped? %>
          <% row_groups.each do |group| %>
            <tr class="bali-table-group-row">
              <%= tag.td(group_header_text(group), colspan: group_colspan, class: "bg-base-300 border-l-4 border-l-primary font-semibold text-sm text-base-content") %>
            </tr>
            <% group.rows.each do |row| %><%= row %><% end %>
          <% end %>
        <% else %>
        <%# Kept at this indent so the no-group output is byte-identical to the pre-grouping template. %>
        <% rows.each do |row| %><%= row %><% end %>
        <% end %>
      <% else %>
        <tr id="<%= empty_table_row_id %>">
          <td class="empty-table text-center" colspan="<%= headers.count %>">
            <% if custom_empty_state_content.present? %>
              <div class="<%= Bali::EmptyState::Component.container_classes %>">
                <%= custom_empty_state_content %>
              </div>
            <% else %>
              <%= render Bali::EmptyState::Component.new(title: empty_state_title) do |empty_state| %>
                <% if empty_state_cta.present? %>
                  <% empty_state.with_cta do %><%= empty_state_cta %><% end %>
                <% end %>
              <% end %>
            <% end %>
          </td>
        </tr>
      <% end %>
    <% end %>
    <% if footers.any? %>
      <tfoot>
        <% footers.each do |footer| %><%= footer %><% end %>
      </tfoot>
    <% end %>
  <% end %>
  <% if bulk_actions? %>
    <div class="bulk-actions-container fixed bottom-4 left-1/2 -translate-x-1/2 bg-base-300 rounded-box shadow-lg p-4 hidden z-50" data-table-target="actionsContainer">
      <div class="flex items-center gap-4">
        <span class="badge badge-primary" data-table-target="selectedCount">0</span>
        <div class="flex gap-2">
          <% @bulk_actions.each do |action| %>
            <%= render Bali::Table::BulkAction::Component.new(**action) %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
