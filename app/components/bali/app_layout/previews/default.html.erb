<%# transform creates a containing block that traps position:fixed elements inside the preview pane %>
<div style="transform: translateZ(0); position: relative; height: 100vh; overflow: hidden;">
<%= render Bali::AppLayout::Component.new(fixed_sidebar: true) do |layout|
  layout.with_sidebar do %>
    <%= render Bali::SideMenu::Component.new(current_path: '/admin', collapsible: collapsible, brand: 'MovieDB') do |menu|
      menu.with_menu_switch(title: 'MovieDB', icon: 'clapperboard', href: '/admin', active: true)
      menu.with_menu_switch(title: 'Analytics', icon: 'bar-chart-3', href: '#')

      menu.with_list(title: 'Main') do |list|
        list.with_item(name: 'Dashboard', href: '/admin', icon: 'layout-dashboard', match: :exact)
        list.with_item(name: 'Movies', href: '/admin/movies', icon: 'film', match: :crud)
        list.with_item(name: 'Studios', href: '/admin/studios', icon: 'building-2', match: :crud)
      end

      menu.with_list(title: 'Reports') do |list|
        list.with_item(name: 'Analytics', href: '#', icon: 'bar-chart-3')
        list.with_item(name: 'Revenue', href: '#', icon: 'dollar-sign')
      end

      menu.with_bottom_item(name: 'Ana García', href: '#', icon: 'circle-user')
      menu.with_bottom_group(name: 'Configuration', icon: 'settings') do |group|
        group.with_item(name: 'Profile', href: '#', icon: 'circle-user')
        group.with_item(name: 'Settings', href: '#', icon: 'settings')
        group.with_item(name: 'Documentation', href: '#', icon: 'book-open')
        group.with_item(name: 'Log Out', href: '#', icon: 'log-out')
      end
    end %>
  <% end

  layout.with_body do %>
    <div class="max-w-7xl">
      <%= render Bali::PageHeader::Component.new(title: 'Dashboard', subtitle: 'Welcome back, Ana') %>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <% [
          { label: 'Total Movies', value: '1,234', icon: 'film', color: 'primary' },
          { label: 'Studios', value: '56', icon: 'building-2', color: 'secondary' },
          { label: 'Revenue', value: '$45.2K', icon: 'dollar-sign', color: 'success' },
          { label: 'Users', value: '892', icon: 'users', color: 'info' }
        ].each do |stat| %>
          <%= render Bali::Card::Component.new(style: :bordered, body_class: 'p-4') do %>
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-base-content/60"><%= stat[:label] %></p>
                <p class="text-2xl font-bold"><%= stat[:value] %></p>
              </div>
              <%= render Bali::Icon::Component.new(stat[:icon], class: "size-8 text-#{stat[:color]}") %>
            </div>
          <% end %>
        <% end %>
      </div>

      <%= render Bali::Card::Component.new(style: :bordered) do %>
        <h3 class="card-title text-lg mb-4">Recent Activity</h3>
        <p class="text-base-content/60">This is a preview of the AppLayout component with a fixed sidebar.</p>
      <% end %>
    </div>
  <% end
end %>
</div>
