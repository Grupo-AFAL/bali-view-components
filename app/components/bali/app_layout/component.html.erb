<div class="<%= container_classes %>" <%= tag.attributes(container_data_attributes) %>>
  <%# Banner (impersonation, maintenance, beta) %>
  <% if banner? %>
    <div class="app-layout-banner"><%= banner %></div>
  <% end %>

  <%# Navbar (full-width) %>
  <% if navbar? %>
    <div class="app-layout-navbar"><%= navbar %></div>
  <% end %>

  <%# Sidebar %>
  <% if sidebar? %>
    <%= sidebar %>
  <% end %>

  <%# Main content area %>
  <div class="app-layout-content flex-1 min-w-0 flex flex-col min-h-screen bg-base-200">
    <%# Optional topbar %>
    <% if topbar? %>
      <div class="app-layout-topbar">
        <%= topbar %>
      </div>
    <% end %>

    <%# Toast notifications - above body, outside scroll context %>
    <% if render_toast? %>
      <div id="toast-notifications">
        <%= render Bali::FlashNotifications::Component.new(
          notice: flash_notice,
          alert: flash_alert
        ) %>
      </div>
    <% end %>

    <%# Body with optional Stimulus controllers for modal/drawer %>
    <main class="flex-1 p-6"<% if main_controller.present? %> data-controller="<%= main_controller %>"<% end %>>
      <%= body? ? body : content %>

      <%# Modal shell - loaded on demand via Turbo Frame %>
      <% if render_modal? %>
        <%= render Bali::Modal::Component.new(id: "main-modal", active: false, size: @modal[:size]) do %>
          <%= render Bali::Skeleton::Component.new(variant: :modal) %>
        <% end %>
      <% end %>

      <%# Drawer shell - loaded on demand via Turbo Frame %>
      <% if render_drawer? %>
        <%= render Bali::Drawer::Component.new(
          drawer_id: "main-drawer",
          size: @drawer[:size],
          active: false
        ) do %>
          <%= render Bali::Skeleton::Component.new(variant: :list, lines: 5) %>
        <% end %>
      <% end %>
    </main>
  </div>
</div>
