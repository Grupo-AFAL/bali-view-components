<body class="<%= container_classes %>" <%= tag.attributes(container_attributes) %>>
  <%# 1. Banner (impersonation, maintenance, beta) %>
  <% if banner? %>
    <div class="app-layout-banner"><%= banner %></div>
  <% end %>

  <%# 2. Navbar (full-width) %>
  <% if navbar? %>
    <div class="app-layout-navbar"><%= navbar %></div>
  <% end %>

  <%# 3. Main area: sidebar + content %>
  <div class="app-layout-main flex flex-1 min-h-0">
    <% if sidebar? %><%= sidebar %><% end %>

    <div class="app-layout-content flex-1 min-w-0 flex flex-col">
      <% if topbar? %>
        <div class="app-layout-topbar"><%= topbar %></div>
      <% elsif render_default_mobile_topbar? %>
        <div class="app-layout-topbar app-layout-topbar--default-mobile flex items-center gap-2 px-4 py-2 bg-base-100 border-b border-base-300 lg:hidden">
          <label for="<%= default_mobile_trigger_id %>"
                 class="btn btn-ghost btn-sm"
                 aria-label="<%= toggle_mobile_label %>">
            <%= render Bali::Icon::Component.new('menu', size: :small) %>
          </label>
          <% if @app_name.present? %>
            <span class="font-semibold text-sm"><%= @app_name %></span>
          <% end %>
        </div>
      <% end %>

      <main class="flex-1" <%= tag.attributes(main_attributes) %>>
        <div class="<%= body_container_classes %>">
          <%= body? ? body : content %>
        </div>

        <% if @modal %>
          <%= render Bali::Modal::Component.new(id: "main-modal", active: false, size: @modal_size) do %>
            <%= render Bali::Skeleton::Component.new(variant: :modal) %>
          <% end %>
        <% end %>

        <% if @drawer %>
          <%= render Bali::Drawer::Component.new(
            drawer_id: "main-drawer",
            size: @drawer_size,
            active: false
          ) do %>
            <%= render Bali::Skeleton::Component.new(variant: :list, lines: 5) %>
          <% end %>
        <% end %>
      </main>
    </div>
  </div>

  <%# 4. Toast notifications (fixed bottom-right, stacking upward) %>
  <% if render_toast? %>
    <div id="toast-notifications" class="fixed bottom-4 left-4 right-4 sm:left-auto sm:min-w-80 sm:max-w-sm z-[101] flex flex-col gap-3 pointer-events-none" role="status" aria-live="polite">
      <div class="flex flex-col gap-3 pointer-events-auto">
        <%= render Bali::FlashNotifications::Component.new(
          notice: flash_notice,
          alert: flash_alert
        ) %>
      </div>
    </div>
  <% end %>
</body>
