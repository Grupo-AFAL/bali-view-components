<div class="bg-base-100 rounded-xl shadow-sm border border-base-200 p-4 <%= options[:class] %>">
  <h3 class="font-semibold mb-3 flex items-center gap-2">
    <%= render Bali::Tag::Component.new(text: " ", color: color, size: :sm) %>
    <%= title %>
    <% if display_count > 0 %>
      <%= render Bali::Tag::Component.new(text: display_count.to_s, color: :ghost, size: :sm) %>
    <% end %>
  </h3>

  <%= render Bali::SortableList::Component.new(**sortable_options, class: "space-y-2 min-h-[100px]") do %>
    <% cards.each do |card| %>
      <%= card %>
    <% end %>
  <% end %>
</div>
