<div class="dashboard-page-component">
  <%= render_breadcrumbs %>

  <%= render Bali::PageHeader::Component.new(
    title: title,
    subtitle: subtitle,
    class: breadcrumb_spacer_class
  ) do |header| %>
    <% if actions? %>
      <div class="flex items-center gap-2">
        <% actions.each do |action| %><%= action %><% end %>
      </div>
    <% end %>
  <% end %>

  <% if stats? %>
    <div class="<%= stats_grid_classes %> mb-6">
      <% stats.each do |stat| %>
        <%= render Bali::Card::Component.new(style: :bordered, body_class: 'p-4') do %>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-base-content/60"><%= stat.label %></p>
              <p class="text-2xl font-bold"><%= stat.value %></p>
              <% if stat.change.present? %>
                <p class="text-xs <%= stat_icon_color(stat.color) %> mt-1"><%= stat.change %></p>
              <% end %>
            </div>
            <% if stat.icon.present? %>
              <%= render Bali::Icon::Component.new(stat.icon, class: "size-8 #{stat_icon_color(stat.color)}") %>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if body? %>
    <%= body %>
  <% end %>
</div>
