<div class="dashboard-page-component">
  <%= render_breadcrumbs %>

  <%= render Bali::PageHeader::Component.new(
    title: title,
    subtitle: subtitle,
    class: breadcrumb_spacer_class
  ) do |header| %>
    <%= render_actions_bar %>
  <% end %>

  <% if stats? %>
    <div class="<%= stats_grid_classes %> mb-6">
      <% stats.each do |stat| %>
        <%= render 'bali/dashboard_page/stat_card', stat: stat %>
      <% end %>
    </div>
  <% end %>

  <% if body? %>
    <%= body %>
  <% end %>
</div>
