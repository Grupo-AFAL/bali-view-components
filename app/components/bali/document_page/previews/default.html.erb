<%= render Bali::DocumentPage::Component.new(
  title: title,
  subtitle: subtitle,
  breadcrumbs: [
    { name: "Dashboard", href: "/lookbook" },
    { name: "Documents", href: "/lookbook" },
    { name: title }
  ]
) do |page| %>
  <% page.with_title_tag do %>
    <%= render Bali::Tag::Component.new(text: "Published", color: :success, size: :sm) %>
  <% end %>

  <% page.with_action do %>
    <%= render Bali::Button::Component.new(name: "Edit", variant: :primary, size: :sm, icon_name: "pencil") %>
  <% end %>

  <% page.with_metadata do %>
    <div class="space-y-4">
      <div>
        <p class="text-xs text-base-content/50 uppercase tracking-wider mb-1">Status</p>
        <p class="text-sm font-medium text-success">Published</p>
      </div>
      <div>
        <p class="text-xs text-base-content/50 uppercase tracking-wider mb-1">Author</p>
        <p class="text-sm">Demo User</p>
      </div>
      <div>
        <p class="text-xs text-base-content/50 uppercase tracking-wider mb-1">Word Count</p>
        <p class="text-sm">342</p>
      </div>
      <div>
        <p class="text-xs text-base-content/50 uppercase tracking-wider mb-1">Versions</p>
        <p class="text-sm">3</p>
      </div>
    </div>
  <% end %>

  <% page.with_preview do %>
    <div class="prose max-w-none">
      <h2>Executive Summary</h2>
      <p>This document outlines the key objectives and milestones for the upcoming quarter. Our team has been working diligently on several initiatives that will significantly impact our product roadmap.</p>
      <h2>Goals</h2>
      <p>The primary focus areas include platform stability, user experience improvements, and expanding our integration ecosystem.</p>
    </div>
  <% end %>
<% end %>
