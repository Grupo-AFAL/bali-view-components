<%= render Bali::IndexPage::Component.new(
  title: 'Movies',
  subtitle: '24 movies total',
  breadcrumbs: [
    { name: 'Dashboard', href: '/lookbook', icon_name: 'home' },
    { name: 'Movies' }
  ]
) do |page| %>
  <% page.with_action do %>
    <%= render Bali::Link::Component.new(name: 'New Movie', href: '#', variant: :primary, icon_name: 'plus') %>
  <% end %>
  <% page.with_nav do %>
    <%# Level 1: section tabs (style: :border, icon + label) %>
    <%= render Bali::Tabs::Component.new(style: :border) do |tabs| %>
      <% tabs.with_tab(title: 'All', icon: 'list', href: '#', active: true) %>
      <% tabs.with_tab(title: 'Upcoming', icon: 'clock', href: '#') %>
      <% tabs.with_tab(title: 'Archived', icon: 'archive', href: '#') %>
    <% end %>
    <%# Level 2: sub-section segment (style: :box, size: :sm, no icons) %>
    <div class="mt-2">
      <%= render Bali::Tabs::Component.new(style: :box, size: :sm) do |tabs| %>
        <% tabs.with_tab(title: 'Releases', href: '#', active: true) %>
        <% tabs.with_tab(title: 'Premieres', href: '#') %>
      <% end %>
    </div>
  <% end %>
  <% page.with_body do %>
    <%= render Bali::Card::Component.new(style: :bordered) do %>
      <p class="text-base-content/60">DataTable would go here.</p>
    <% end %>
  <% end %>
<% end %>
