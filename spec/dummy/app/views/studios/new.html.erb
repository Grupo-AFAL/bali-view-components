<% if params[:layout] == 'false' %>
  <h2 class="text-lg font-semibold mb-4"><%= t('studios.form.new_title') %></h2>
  <%= render 'form', studio: @studio %>
<% else %>
  <%= render Bali::PageHeader::Component.new(
    title: t('studios.form.new_title'),
    back: { href: studios_path }
  ) %>

  <%= render 'form', studio: @studio %>
<% end %>
