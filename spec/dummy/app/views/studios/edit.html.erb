<% if params[:layout] == 'false' %>
  <h2 class="text-lg font-semibold mb-4"><%= t('studios.form.edit_title', name: @studio.name) %></h2>
  <%= render 'form', studio: @studio %>
<% else %>
  <%= render Bali::PageHeader::Component.new(
    title: t('studios.form.edit_title', name: @studio.name),
    back: { href: studio_path(@studio) }
  ) %>

  <%= render 'form', studio: @studio %>
<% end %>
