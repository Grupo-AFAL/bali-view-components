<% if params[:layout] == 'false' %>
  <h2 class="text-lg font-semibold mb-4">Edit <%= @studio.name %></h2>
  <%= render 'form', studio: @studio %>
<% else %>
  <%= render Bali::PageHeader::Component.new(
    title: "Edit #{@studio.name}",
    back: { href: studio_path(@studio) }
  ) %>

  <%= render 'form', studio: @studio %>
<% end %>
