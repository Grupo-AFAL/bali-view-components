<!DOCTYPE html>
<html data-theme="light">
  <head>
    <% content_for(:title) { "Kitchen Sink Demo" } %>
    <%= render "layouts/head" %>
  </head>
  <%= render Bali::AppLayout::Component.new(
    flash: flash,
    body_container: :contained,
    class: "bg-base-200",
    data: { controller: "theme-switcher" }
  ) do |layout| %>
    <% layout.with_navbar do %>
      <%= render 'layouts/navbar' %>
    <% end %>

    <% layout.with_body do %>
      <%= yield %>
    <% end %>
  <% end %>
</html>
