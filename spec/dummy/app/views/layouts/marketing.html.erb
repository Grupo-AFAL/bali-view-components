<!DOCTYPE html>
<html data-theme="light">
  <head>
    <% content_for(:title) { "The Ultimate Movie Database" } %>
    <%= render "layouts/head" %>
  </head>
  <%= render Bali::AppLayout::Component.new(
    modal: false,
    drawer: false,
    flash: flash,
    class: "bg-base-100",
    body_container: :full
  ) do |layout| %>
    <% layout.with_navbar do %>
      <%= render 'layouts/marketing_navbar' %>
    <% end %>

    <% layout.with_body do %>
      <%= yield %>
      <%= render 'layouts/marketing_footer' %>
    <% end %>
  <% end %>
</html>
