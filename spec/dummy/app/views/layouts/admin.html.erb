<!DOCTYPE html>
<html data-theme="light">
  <head>
    <% content_for(:title) { "#{t('app.name')} Admin" } %>
    <%= render "layouts/head" %>
  </head>
  <%= render Bali::AppLayout::Component.new(fixed_sidebar: true, flash: flash) do |layout| %>
    <% layout.with_sidebar do %>
      <%= render 'layouts/admin_sidebar' %>
    <% end %>

    <% layout.with_topbar do %>
      <%= render 'layouts/admin_topbar' %>
    <% end %>

    <% layout.with_body do %>
      <%= yield %>
    <% end %>
  <% end %>

  <%# FeedbackWidget - floats on all admin pages %>
  <%= render Bali::FeedbackWidget::Component.new(
    project_slug: "bali-demo",
    opina_url: "http://localhost:3008",
    secret: "dev-shared-secret",
    user_id: 1,
    email: "demo@example.com"
  ) %>
</html>
