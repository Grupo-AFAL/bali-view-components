<div class="flex flex-col items-center justify-center min-h-screen">
  <%= render Bali::Link::Component.new(name: 'MovieDB', href: landing_path, class: 'text-2xl font-bold mb-6') %>
  <%= render Bali::Card::Component.new(style: :bordered, body_class: "p-8") do %>
    <div class="w-80">
      <div class="text-center mb-6">
        <h1 class="text-2xl font-bold">Welcome back</h1>
        <p class="text-sm text-base-content/60 mt-1">Sign in to your MovieDB account</p>
      </div>

      <%= form_with url: login_path, method: :post, class: "space-y-4" do |f| %>
        <div class="form-control">
          <label class="label"><span class="label-text">Email</span></label>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <%= render Bali::Icon::Component.new('mail', size: :small, class: 'text-base-content/40') %>
            <input type="email" name="email" placeholder="you@example.com" class="grow" required />
          </label>
        </div>

        <div class="form-control">
          <label class="label">
            <span class="label-text">Password</span>
            <%= render Bali::Link::Component.new(
              name: 'Forgot password?',
              href: forgot_password_path,
              class: 'label-text-alt link link-hover'
            ) %>
          </label>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <%= render Bali::Icon::Component.new('lock', size: :small, class: 'text-base-content/40') %>
            <input type="password" name="password" placeholder="••••••••" class="grow" required />
          </label>
        </div>

        <%= render Bali::Button::Component.new(name: 'Sign in', variant: :primary, type: :submit, class: 'w-full') %>
      <% end %>

      <div class="divider text-xs text-base-content/40 my-6">OR</div>

      <div class="space-y-2">
        <%= render Bali::Button::Component.new(name: 'Continue with Google', variant: :outline, class: 'w-full') %>
      </div>

      <p class="text-center text-sm text-base-content/60 mt-6">
        Don't have an account?
        <%= render Bali::Link::Component.new(name: 'Create one', href: register_path) %>
      </p>
    </div>
  <% end %>
</div>
