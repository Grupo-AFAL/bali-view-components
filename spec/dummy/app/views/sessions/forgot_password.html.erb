<div class="flex flex-col items-center justify-center min-h-screen">
  <%= render Bali::Link::Component.new(name: 'MovieDB', href: landing_path, class: 'text-2xl font-bold mb-6') %>
  <%= render Bali::Card::Component.new(style: :bordered, body_class: "p-8") do %>
    <div class="w-80">
      <div class="text-center mb-6">
        <%= render Bali::Icon::Component.new('key-round', class: 'size-10 text-primary mx-auto mb-3') %>
        <h1 class="text-2xl font-bold">Reset password</h1>
        <p class="text-sm text-base-content/60 mt-1">Enter your email and we'll send you a reset link</p>
      </div>

      <%= form_with url: forgot_password_path, method: :post, class: "space-y-4" do |f| %>
        <div class="form-control">
          <label class="label"><span class="label-text">Email</span></label>
          <label class="input input-bordered flex items-center gap-2 w-full">
            <%= render Bali::Icon::Component.new('mail', size: :small, class: 'text-base-content/40') %>
            <input type="email" name="email" placeholder="you@example.com" class="grow" required />
          </label>
        </div>

        <%= render Bali::Button::Component.new(name: 'Send reset link', variant: :primary, type: :submit, class: 'w-full') %>
      <% end %>

      <p class="text-center text-sm text-base-content/60 mt-6">
        Remember your password?
        <%= render Bali::Link::Component.new(name: 'Back to sign in', href: login_path) %>
      </p>
    </div>
  <% end %>
</div>
