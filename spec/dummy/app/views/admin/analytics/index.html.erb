<%# Admin Analytics - Showcases: DashboardPage, Chart (line/doughnut/bar), Progress, Heatmap,
    Table, Tag, Tooltip, Tabs, Notification, List, GanttChart, Clipboard, Loader %>

<%= render Bali::DashboardPage::Component.new(
  title: 'Analytics',
  subtitle: 'Movie production insights and trends'
) do |page| %>
  <% page.with_stat(label: 'Total Movies', value: @total_movies.to_s, icon: 'film', color: :primary) %>
  <% page.with_stat(label: 'Total Views', value: number_with_delimiter(@total_views), icon: 'eye', color: :info) %>
  <% page.with_stat(label: 'Avg Rating', value: @avg_rating.to_s, icon: 'star', color: :warning) %>
  <% page.with_stat(label: 'Completion', value: "#{@completion_rate}%", icon: 'check-circle', color: :success) %>

  <% page.with_body do %>
    <%# Notifications - different types %>
    <div class="space-y-2 mb-6">
      <%= render Bali::Notification::Component.new(type: :info, dismiss: true) do %>
        <strong>Pro tip:</strong> Use the tabs below to switch between different chart views.
      <% end %>
    </div>

    <%# Tabs - Production overview with different chart types %>
    <%= render Bali::Card::Component.new(style: :bordered) do %>
      <%= render Bali::Tabs::Component.new(style: :lifted) do |tabs| %>
        <% tabs.with_tab(title: 'Trend', active: true) do %>
          <div class="p-4">
            <h3 class="text-lg font-semibold mb-2">Monthly Production Trend</h3>
            <p class="text-sm text-base-content/60 mb-4">Movies added per month over the last 7 months</p>
            <%= render Bali::Chart::Component.new(
              type: :line,
              data: @monthly_production,
              legend: false,
              class: 'h-[300px]'
            ) %>
          </div>
        <% end %>
        <% tabs.with_tab(title: 'By Genre') do %>
          <div class="p-4">
            <h3 class="text-lg font-semibold mb-2">Distribution by Genre</h3>
            <p class="text-sm text-base-content/60 mb-4">Breakdown of movies across genres</p>
            <%= render Bali::Chart::Component.new(
              type: :doughnut,
              data: @movies_by_genre,
              legend: true,
              class: 'h-[300px]'
            ) %>
          </div>
        <% end %>
        <% tabs.with_tab(title: 'By Status') do %>
          <div class="p-4">
            <h3 class="text-lg font-semibold mb-2">Production Status</h3>
            <p class="text-sm text-base-content/60 mb-4">Current status of all movies in the database</p>
            <%= render Bali::Chart::Component.new(
              type: :bar,
              data: @movies_by_status,
              legend: false,
              class: 'h-[300px]'
            ) %>
          </div>
        <% end %>
      <% end %>
    <% end %>

    <%# Top Movies and Heatmap Row %>
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6 mt-6">
      <%# Top Rated Movies with Tooltips %>
      <%= render Bali::Card::Component.new(style: :bordered) do %>
        <div class="flex items-center gap-2 mb-4">
          <h3 class="card-title text-lg">Top Rated Movies</h3>
          <%= render Bali::Tooltip::Component.new(text: 'Movies sorted by rating, highest first', position: :right) do %>
            <%= render Bali::Icon::Component.new('info', size: :small, class: 'text-base-content/40 cursor-help') %>
          <% end %>
        </div>
        <% if @top_movies.any? %>
          <%= render Bali::Table::Component.new do |t| %>
            <% t.with_header(name: '#') %>
            <% t.with_header(name: 'Movie') %>
            <% t.with_header(name: 'Genre') %>
            <% t.with_header(name: 'Rating', align: :right) %>

            <% @top_movies.each_with_index do |movie, i| %>
              <% t.with_row do %>
                <td class="text-base-content/60"><%= i + 1 %></td>
                <td class="font-medium">
                  <%= render Bali::Tooltip::Component.new(text: "#{movie.status.humanize} — #{movie.genre}", position: :top) do %>
                    <%= movie.name %>
                  <% end %>
                </td>
                <td>
                  <%= render Bali::Tag::Component.new(text: movie.genre, size: :sm, style: :outline) %>
                </td>
                <td class="text-right">
                  <% if movie.rating %>
                    <div class="flex items-center justify-end gap-1">
                      <%= render Bali::Icon::Component.new('star', size: :small, class: 'text-warning') %>
                      <span class="font-medium"><%= movie.rating %></span>
                    </div>
                  <% else %>
                    <span class="text-base-content/40">&mdash;</span>
                  <% end %>
                </td>
              <% end %>
            <% end %>
          <% end %>
        <% else %>
          <%= render Bali::Message::Component.new(color: :info) do %>
            No movies to display.
          <% end %>
        <% end %>
      <% end %>

      <%# Activity Heatmap %>
      <%= render Bali::Card::Component.new(style: :bordered) do %>
        <div class="flex items-center justify-between mb-4">
          <h3 class="card-title text-lg">Activity Heatmap</h3>
          <%= render Bali::Tooltip::Component.new(text: 'Shows user activity intensity by day and hour', position: :left) do %>
            <%= render Bali::Icon::Component.new('info', size: :small, class: 'text-base-content/40 cursor-help') %>
          <% end %>
        </div>
        <%= render Bali::Heatmap::Component.new(
          data: @heatmap_data,
          color: :info
        ) do |heatmap| %>
          <% heatmap.with_x_axis_title('Day of Week') %>
          <% heatmap.with_y_axis_title('Hour') %>
          <% heatmap.with_legend_title('Activity') %>
        <% end %>
      <% end %>
    </div>

    <%# Genre Distribution with Progress + Clipboard %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
      <%= render Bali::Card::Component.new(style: :bordered) do %>
        <div class="flex items-center justify-between mb-4">
          <h3 class="card-title text-lg">Genre Distribution</h3>
          <%= render Bali::Clipboard::Component.new(
            text: @movies_by_genre.map { |g, c| "#{g}: #{c}" }.join(', '),
            class: 'btn btn-ghost btn-xs'
          ) do %>
            <%= render Bali::Icon::Component.new('copy', size: :small) %>
            <span class="ml-1">Copy</span>
          <% end %>
        </div>
        <div class="space-y-4">
          <% total = @movies_by_genre.values.sum.to_f %>
          <% colors = %i[primary secondary accent info success warning error] %>
          <% @movies_by_genre.sort_by { |_, v| -v }.each_with_index do |(genre, count), i| %>
            <% pct = total.positive? ? (count / total * 100).round : 0 %>
            <div>
              <div class="flex justify-between mb-1">
                <span class="text-sm font-medium"><%= genre %></span>
                <span class="text-sm text-base-content/60"><%= count %> movies (<%= pct %>%)</span>
              </div>
              <%= render Bali::Progress::Component.new(value: pct, max: 100, color: colors[i % colors.length]) %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# Recent Activity List %>
      <%= render Bali::Card::Component.new(style: :bordered) do %>
        <h3 class="card-title text-lg mb-4">Recent Activity</h3>
        <%= render Bali::List::Component.new do |list| %>
          <% @top_movies.each do |movie| %>
            <% list.with_row do %>
              <div class="flex items-center gap-4 w-full">
                <%= render Bali::Avatar::Component.new(
                  name: movie.name,
                  size: :sm
                ) %>
                <div class="flex-1 min-w-0">
                  <p class="font-medium truncate"><%= movie.name %></p>
                  <p class="text-sm text-base-content/60">
                    <%= movie.genre %> &middot; <%= render Bali::Timeago::Component.new(movie.updated_at, add_suffix: true) %>
                  </p>
                </div>
                <%= render Bali::Tag::Component.new(
                  text: movie.status.humanize,
                  color: movie.done? ? :success : :warning,
                  size: :sm
                ) %>
              </div>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <%# Production Timeline - GanttChart %>
    <div class="mt-6">
      <%= render Bali::Card::Component.new(style: :bordered) do %>
        <h3 class="card-title text-lg mb-4">Production Timeline</h3>
        <% if @gantt_tasks.any? %>
          <div class="overflow-x-auto">
            <%= render Bali::GanttChart::Component.new(
              tasks: @gantt_tasks,
              zoom: :week,
              readonly: true,
              row_height: 40
            ) %>
          </div>
        <% else %>
          <%= render Bali::Message::Component.new(color: :info) do %>
            No movies with timeline data.
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% end %>
<% end %>
