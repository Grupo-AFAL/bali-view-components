<%= form_with model: studio, url: studio.persisted? ? admin_studio_path(studio) : admin_studios_path, class: 'space-y-4', builder: Bali::FormBuilder do |f| %>
  <%= f.error_summary %>

  <%= render Bali::Columns::Component.new(cols: 1, cols_tablet: 2, gap: :lg) do %>
    <%= f.text_field_group :name, required: true %>
    <%= f.select_group :country,
          Studio::COUNTRIES.map { |c| [c, c] },
          { include_blank: t('studios.form.select_country') } %>
    <%= f.select_group :status,
          Studio.statuses.keys.map { |s| [s.humanize, s] },
          { include_blank: t('studios.form.select_status') } %>
    <%= f.select_group :size,
          Studio::SIZES.map { |s| [s.humanize, s] },
          { include_blank: t('studios.form.select_size') } %>
    <%= f.number_field_group :founded_year, min: 1800, max: Date.current.year %>
  <% end %>

  <div class="flex gap-2 justify-end mt-6">
    <% if params[:layout] == 'false' %>
      <%= render Bali::Button::Component.new(
        name: t('common.cancel'),
        variant: :ghost,
        data: { action: 'drawer#close' }
      ) %>
    <% else %>
      <%= render Bali::Link::Component.new(
        name: t('common.cancel'),
        href: studio.persisted? ? admin_studio_path(studio) : admin_studios_path,
        variant: :ghost
      ) %>
    <% end %>
    <%= render Bali::Button::Component.new(
      name: studio.persisted? ? t('studios.form.update') : t('studios.form.create'),
      type: :submit,
      variant: :primary
    ) %>
  </div>
<% end %>
