<%= render Bali::DashboardPage::Component.new(
  title: t('dashboard.title'),
  subtitle: t('dashboard.welcome')
) do |page| %>
  <% page.with_stat(label: t('dashboard.total_movies'), value: @stats[:total_movies].to_s, icon: 'film', color: :primary) %>
  <% page.with_stat(label: t('dashboard.in_production'), value: @stats[:active_productions].to_s, icon: 'clapperboard', color: :warning) %>
  <% page.with_stat(label: t('dashboard.studios'), value: @stats[:studios_count].to_s, icon: 'building-2', color: :secondary) %>
  <% page.with_stat(label: t('dashboard.indie_films'), value: @stats[:indie_count].to_s, icon: 'star', color: :accent) %>

  <% page.with_body do %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <%= render Bali::Card::Component.new(style: :bordered) do %>
        <h3 class="card-title text-lg"><%= t('dashboard.movies_by_genre') %></h3>
        <div class="mt-4">
          <%= render Bali::Chart::Component.new(
            type: :doughnut,
            data: @movies_by_genre,
            legend: true,
            class: 'h-[280px]'
          ) %>
        </div>
      <% end %>

      <%= render Bali::Card::Component.new(style: :bordered) do %>
        <h3 class="card-title text-lg"><%= t('dashboard.recent_activity') %></h3>
        <div class="mt-4">
          <%= render Bali::Timeline::Component.new(position: :left) do |timeline| %>
            <% timeline.with_tag_header(text: t('dashboard.today')) %>
            <% @recent_movies.first(3).each do |movie| %>
              <% timeline.with_tag_item(
                heading: movie.name,
                icon: movie.done? ? 'check' : 'edit',
                color: movie.status_color
              ) do %>
                <div class="flex items-center gap-2">
                  <%= render Bali::Tag::Component.new(text: movie.genre, size: :sm, style: :outline) %>
                  <span class="text-sm text-base-content/60">
                    <%= render Bali::Timeago::Component.new(movie.created_at, add_suffix: true) %>
                  </span>
                </div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>
