<%= render Bali::DashboardPage::Component.new(
  title: 'Dashboard',
  subtitle: 'Welcome back, Ana'
) do |page| %>
  <% page.with_stat(label: 'Total Movies', value: @total_movies.to_s, icon: 'film', color: :primary) %>
  <% page.with_stat(label: 'In Production', value: @active_productions.to_s, icon: 'clapperboard', color: :warning) %>
  <% page.with_stat(label: 'Studios', value: @studios_count.to_s, icon: 'building-2', color: :secondary) %>
  <% page.with_stat(label: 'Indie Films', value: @indie_count.to_s, icon: 'star', color: :accent) %>

  <% page.with_body do %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <%= render Bali::Card::Component.new(style: :bordered) do %>
        <h3 class="card-title text-lg">Movies by Genre</h3>
        <div class="mt-4">
          <%= render Bali::Chart::Component.new(
            type: :doughnut,
            data: @movies_by_genre,
            legend: true,
            class: 'h-[280px]'
          ) %>
        </div>
      <% end %>

      <%= render Bali::Card::Component.new(style: :bordered) do %>
        <h3 class="card-title text-lg">Recent Activity</h3>
        <div class="mt-4">
          <%= render Bali::Timeline::Component.new(position: :left) do |timeline| %>
            <% timeline.with_tag_header(text: 'Today') %>
            <% @recent_movies.first(3).each do |movie| %>
              <% timeline.with_tag_item(
                heading: movie.name,
                icon: movie.done? ? 'check' : 'edit',
                color: movie.done? ? :success : :warning
              ) do %>
                <div class="flex items-center gap-2">
                  <%= render Bali::Tag::Component.new(text: movie.genre, size: :sm, style: :outline) %>
                  <span class="text-sm text-base-content/60">
                    <%= render Bali::Timeago::Component.new(movie.created_at, add_suffix: true) %>
                  </span>
                </div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>
